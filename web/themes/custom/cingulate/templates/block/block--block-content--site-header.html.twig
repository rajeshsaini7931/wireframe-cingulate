{#
/**
 * @file
 * Template for the Site Header block_content block.
 *
 * Available variables (provided by cingulate_blocks_preprocess_block):
 *   - hcp_notice: String from field_hcp_notice.
 *   - site_name: String from field_site_name or system config fallback.
 *   - header_logo_url: Resolved absolute URL for header logo image (optional).
 *   - header_logo_alt: Alt text for header logo (optional).
 *   - register_cta_url: URL for register CTA link.
 *   - register_cta_title: Button text for register CTA.
 *   - menu_tree: Render array of the main navigation menu tree.
 *
 * @see cingulate_blocks_preprocess_block()
 * @see _cingulate_blocks_preprocess_header()
 *
 * @ingroup themeable
 */
#}
{{ attach_library('cingulate/component-nav') }}

<header id="cmp-nav" role="banner">
  {# HCP Notice Bar #}
  {% if hcp_notice is not empty %}
    <div class="nav__hcp-bar">
      <p>{{ hcp_notice }}</p>
    </div>
  {% endif %}

  {# Main Navigation Row #}
  <nav class="navbar navbar-expand-xl nav__main" aria-label="{{ 'Main navigation'|t }}">
    <div class="nav__left">
      {# Logo or Site Name #}
      {% if header_logo_url is not empty %}
        <a href="/" class="nav__logo" aria-label="{{ site_name }} {{ 'home'|t }}">
          <img src="{{ header_logo_url }}" alt="{{ header_logo_alt }}" class="nav__logo-img" />
        </a>
      {% else %}
        <a href="/" class="nav__logo" aria-label="{{ site_name }} {{ 'home'|t }}">{{ site_name }}</a>
      {% endif %}

      {# Divider #}
      <div class="nav__divider" aria-hidden="true"></div>

      {# Main Menu Tree #}
      {% if menu_tree is not empty %}
        {{ menu_tree }}
      {% endif %}
    </div>

    {# Register CTA Button #}
    {% if register_cta_url is not empty %}
      <a href="{{ register_cta_url }}" class="nav__register">
        {{ register_cta_title|default('Register') }}
      </a>
    {% endif %}
  </nav>
</header>

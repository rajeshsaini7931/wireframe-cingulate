{#
/**
 * @file
 * Template for Resource Materials paragraph.
 *
 * Available variables:
 *   - content.field_section_heading: Section heading
 *
 * @see template_preprocess_paragraph()
 *
 * @ingroup themeable
 */
#}
{{ attach_library('cingulate/component-resources') }}

<section id="cmp-resources">
  {% if content.field_section_heading is not empty %}
    <h2 class="resources__heading">{{ content.field_section_heading }}</h2>
  {% endif %}

  <div class="resources__grid">

    {# Podcasts Card #}
    <article class="resource-card" data-tab="podcasts"
             role="button" tabindex="0"
             aria-expanded="false" aria-controls="resources-items">
      <div class="resource-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
          <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
          <line x1="12" x2="12" y1="19" y2="22"/>
        </svg>
      </div>
      <div class="resource-card__body">
        <h3 class="resource-card__title">Podcasts</h3>
        <p class="resource-card__desc">Lorem ipsum dolor sit amet, consectetur adipiscing elit</p>
      </div>
    </article>

    {# Videos Card #}
    <article class="resource-card" data-tab="videos"
             role="button" tabindex="0"
             aria-expanded="false" aria-controls="resources-items">
      <div class="resource-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m22 8-6 4 6 4V8Z"/>
          <rect width="14" height="12" x="2" y="6" rx="2" ry="2"/>
        </svg>
      </div>
      <div class="resource-card__body">
        <h3 class="resource-card__title">Videos</h3>
        <p class="resource-card__desc">Lorem ipsum dolor sit amet, consectetur adipiscing elit</p>
      </div>
    </article>

    {# Newsletter Card #}
    <article class="resource-card" data-tab="newsletter"
             role="button" tabindex="0"
             aria-expanded="false" aria-controls="resources-items">
      <div class="resource-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/>
          <path d="M14 2v4a2 2 0 0 0 2 2h4"/>
          <line x1="10" x2="14" y1="13" y2="13"/>
          <line x1="8"  x2="16" y1="17" y2="17"/>
          <line x1="8"  x2="10" y1="9"  y2="9"/>
        </svg>
      </div>
      <div class="resource-card__body">
        <h3 class="resource-card__title">Newsletter</h3>
        <p class="resource-card__desc">Register for newsletters</p>
      </div>
    </article>

  </div>

  {# Items list — shown when a card is clicked #}
  <div class="resources__items" id="resources-items">
    {% if content.field_resource_items is not empty %}
      <div class="resources__item-grid">
        {{ content.field_resource_items }}
      </div>
    {% endif %}
  </div>

  {# Video Player Modal #}
  <div class="modal fade" id="resourcePlayerModal" tabindex="-1" aria-labelledby="resourcePlayerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-body p-4">
          <div class="resources__player-top">
            <button type="button" class="resources__player-close" data-bs-dismiss="modal" aria-label="Close">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </button>
          </div>

          <div class="resources__player-video mb-4" id="videoPlayerContainer">
            {# Vimeo iframe will be injected here #}
          </div>

          <div class="resources__player-meta mb-3">
            <p class="resources__player-title" id="playerTitle">Video Title</p>
            <p class="resources__player-topic" id="playerTopic">Topic</p>
          </div>

          <div class="resources__player-transcript">
            <button class="resources__player-transcript-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#transcriptBody" aria-expanded="false" aria-controls="transcriptBody">
              <span>View Transcript</span>
              <svg class="resources__player-transcript-chevron is-closed" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
            <div class="collapse" id="transcriptBody">
              <p class="resources__player-transcript-body mt-3">
                This is a placeholder for the video transcript. The actual transcript content will be provided by the team and can be dynamically loaded based on the selected resource item.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

</section>

{#
/**
 * @file
 * Template for the site_header block content type.
 *
 * Activated by Drupal's template suggestion:
 *   block--block-content--site-header.html.twig
 *
 * Variables injected by cingulate_blocks_preprocess_block():
 *   - utility_text: Utility bar message string.
 *   - site_name: Site name from system.site config.
 *   - header_logo_url: Absolute URL of the header logo image (empty if not set).
 *   - header_logo_alt: Alt text for the header logo.
 *   - menu_tree: Header navigation menu render array (theme: menu__cingulate_header).
 *
 * @see \Drupal\block_content\Entity\BlockContent
 * @see cingulate_blocks_preprocess_block()
 * @see menu--cingulate-header.html.twig
 *
 * @ingroup themeable
 */
#}

<header id="cmp-header" role="banner">

  {# Utility Bar #}
  {% if utility_text is not empty %}
    <div class="header__utility-bar">
      <p>{{ utility_text }}</p>
    </div>
  {% endif %}

  {# Main Navigation #}
  <nav class="header__nav navbar navbar-expand-xl" aria-label="{{ 'Main navigation'|t }}">
    <div class="container-fluid px-0 align-items-center w-100">

      {# Logo — image from Media Library if uploaded, otherwise site name text #}
      <a
        href="{{ path('<front>') }}"
        class="header__logo flex-shrink-0 text-nowrap"
        aria-label="{{ site_name }} {{ 'home'|t }}"
      >
        {% if header_logo_url is not empty %}
          <img
            src="{{ header_logo_url }}"
            alt="{{ header_logo_alt is not empty ? header_logo_alt : site_name }}"
            class="header__logo-img"
          />
        {% else %}
          {{ site_name }}
        {% endif %}
      </a>

      {# Vertical divider (desktop only) #}
      <span class="header__divider d-none d-xl-block flex-shrink-0" aria-hidden="true"></span>

      {# Nav items + register CTA + hamburger + mobile collapse
         All rendered via menu--cingulate-header.html.twig #}
      {{ menu_tree }}

    </div>
  </nav>

</header>

{#
/**
 * @file
 * Template for the Site Footer block_content block.
 *
 * Available variables (provided by cingulate_blocks_preprocess_block):
 *   - footer_logo_url: Resolved absolute URL for footer logo image (optional).
 *   - footer_logo_alt: Alt text for footer logo (optional).
 *   - menu_tree: Render array of the footer navigation menu tree.
 *   - copyright_text: Markup from field_copyright_text.
 *
 * @see cingulate_blocks_preprocess_block()
 * @see _cingulate_blocks_preprocess_footer()
 *
 * @ingroup themeable
 */
#}
{{ attach_library('cingulate/component-footer') }}

<footer id="cmp-footer" role="contentinfo">
  {# Logo Placeholder #}
  <div class="footer__logo-wrap">
    {% if footer_logo_url is not empty %}
      <img src="{{ footer_logo_url }}" alt="{{ footer_logo_alt }}" class="footer__logo-img" />
    {% else %}
      <span>Company Logo</span>
    {% endif %}
  </div>

  {# Legal Nav + Copyright #}
  <div class="footer__legal">
    <nav aria-label="Footer legal navigation">
      {# Footer Menu Tree #}
      {% if menu_tree is not empty %}
        {{ menu_tree }}
      {% endif %}
    </nav>

    {# Divider #}
    <hr class="footer__divider" aria-hidden="true" />

    {# Copyright Text #}
    {% if copyright_text is not empty %}
      <p class="footer__copyright">{{ copyright_text }}</p>
    {% endif %}
  </div>
</footer>

{#
/**
 * @file
 * Template for the Cingulate site header navigation menu.
 *
 * Renders main navigation with dropdown support.
 *
 * Available variables:
 *   - items: A nested list of menu items. Each item contains:
 *     - title: Menu link title (TranslatableMarkup).
 *     - url: Url object.
 *     - below: Array of child menu items.
 *     - in_active_trail: TRUE if item is in active trail.
 *   - menu_name: The machine name of the menu.
 *
 * @see cingulate_blocks_preprocess_block()
 * @see template_preprocess_menu()
 *
 * @ingroup themeable
 */
#}

<ul class="nav__links" role="list">
  {% for item in items %}
    <li class="nav__item{% if item.below %} has-dropdown{% endif %}{% if item.in_active_trail %} is-active-trail{% endif %}">

      {% if item.below %}
        {# Parent item — button with dropdown #}
        <button
          class="nav__link"
          type="button"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="dropdown-{{ item.title|clean_class }}"
        >
          {{ item.title }}
          <svg class="nav__chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>

        {# Dropdown submenu #}
        <ul
          class="nav__dropdown"
          id="dropdown-{{ item.title|clean_class }}"
          role="menu"
          aria-label="{{ item.title }} submenu"
        >
          {% for sub in item.below %}
            <li role="none">
              <a
                href="{{ sub.url }}"
                role="menuitem"
                {% if sub.in_active_trail %}aria-current="page"{% endif %}
              >{{ sub.title }}</a>
            </li>
          {% endfor %}
        </ul>

      {% else %}
        {# Leaf item — direct link #}
        <a
          href="{{ item.url }}"
          class="nav__link{% if item.in_active_trail %} is-active{% endif %}"
          {% if item.in_active_trail %}aria-current="page"{% endif %}
        >
          {{ item.title }}
        </a>
      {% endif %}

    </li>
  {% endfor %}
</ul>
